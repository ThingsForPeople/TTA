# ── Tier 1: Zero config ──────────────────────────────────────────────
# No env vars needed. Run `npm run dev` and go.
# Team scraping, analysis, optimizer, and localStorage persistence all work.
# Auth and database features are disabled automatically.

# ── Tier 2: Local dev with database ─────────────────────────────────
# AUTH_DISABLED=true
# NEXT_PUBLIC_AUTH_DISABLED=true
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/tiny_teams

# ── Tier 3: Full production ─────────────────────────────────────────
# Clerk (auth)
# NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
# CLERK_SECRET_KEY=
# CLERK_WEBHOOK_SECRET=
# NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/app
# NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/app

# Postgres (Neon, Supabase, local, etc.)
# DATABASE_URL=

# ── AI (optional, any tier) ─────────────────────────────────────────
# Groq (production AI — free tier available)
# GROQ_API_KEY=

# Google Gemini (alternative AI provider)
# GEMINI_API_KEY=
# GEMINI_MODEL=gemini-3.1-flash-lite
